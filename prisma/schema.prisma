generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id // Supabase auth.users.id (uuid)
  email       String       @unique
  name        String?
  avatarUrl   String?
  role        String       @default("client") // "admin" | "client"
  businesses  Business[]
  credentials Credential[]
  createdAt   DateTime     @default(now())
}

model Business {
  id                 String         @id @default(cuid())
  name               String
  wabaId             String?        @unique // Meta's WhatsApp Business Account id, informational
  systemPrompt       String
  welcomeMessage     String
  businessInfo       Json
  model              String? // null = inherit AppConfig.chatModel
  visionModel        String? // null = inherit AppConfig.visionModel
  audioModel         String? // null = inherit AppConfig.audioModel
  maxHistoryMessages Int            @default(20)
  dailyAiLimit       Int            @default(1000)
  isActive           Boolean        @default(true)
  ownerId            String
  owner              User           @relation(fields: [ownerId], references: [id])
  aiCredentialId     String?
  phoneNumbers       PhoneNumber[]
  conversations      Conversation[]
  appointments       Appointment[]
  createdAt          DateTime       @default(now())

  @@index([ownerId])
}

// A phone number registered under a Business (WABA). A Business can hold more
// than one PhoneNumber; conversations belong to the number the customer
// actually messaged, not to the WABA directly.
model PhoneNumber {
  id                   String         @id @default(cuid())
  businessId           String
  business             Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phoneNumberId        String         @unique // Meta's opaque technical id — webhook lookup key
  displayPhone         String? // human-readable "+<código país> <número>", shown as the item title
  whatsappCredentialId String?
  isActive             Boolean        @default(true)
  conversations        Conversation[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([businessId])
}

// Singleton (id is always "default") holding platform-wide AI defaults —
// editable from /settings/credentials by the admin, no deploy required.
// Business.model/visionModel/audioModel/aiCredentialId fall back to this
// when left unset, so rolling out a new model to every client is a form
// save, not a migration.
model AppConfig {
  id                   String   @id @default("default")
  aiCredentialId       String?
  whatsappCredentialId String?
  chatModel            String   @default("gpt-4o-mini")
  visionModel          String   @default("gpt-4o-mini")
  audioModel           String   @default("whisper-1")
  updatedAt            DateTime @updatedAt
}

model Credential {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id])
  kind         String // "ai" | "whatsapp"
  provider     String // ai: "openai" | "openrouter" | "google" ; whatsapp: "meta"
  label        String
  encryptedKey String // AES-256-GCM: base64(iv):base64(ciphertext):base64(authTag)
  keyLast4     String
  baseUrl      String? // ai only; null = provider default
  lastUsedAt   DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([ownerId, kind])
}

model Conversation {
  id            String        @id @default(cuid())
  businessId    String // denormalized copy of phoneNumber.businessId — kept so RLS policies and scope.ts stay a single-hop join; PhoneNumber.businessId is immutable so this can't drift
  business      Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phoneNumberId String
  phoneNumber   PhoneNumber   @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  customerPhone String
  customerName  String? // WhatsApp profile name from webhook `contacts[0].profile.name` — overwritten on every inbound message, never edited by hand
  nickname      String? // admin-set alias, takes display priority over customerName; webhook never touches this
  status        String        @default("active")
  lastMessageAt DateTime      @default(now()) // denormalized for list ordering — bumped on every message insert
  unreadCount   Int           @default(0) // customer messages since admin last opened the thread
  messages      Message[]
  appointments  Appointment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([phoneNumberId, customerPhone])
  @@index([businessId, lastMessageAt])
  @@index([phoneNumberId, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  mediaType      String       @default("text")
  mediaUrl       String?
  wamid          String?      @unique
  sentBy         String       @default("bot") // "bot" | "human" | "customer"
  status         String       @default("sent") // "sent" | "delivered" | "read" | "failed" (wired in Phase 6)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Appointment {
  id             String        @id @default(cuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  customerPhone  String
  customerName   String
  service        String
  date           String
  time           String
  status         String        @default("pending")
  notes          String?
  createdAt      DateTime      @default(now())
}

model EventLog {
  id            String   @id @default(cuid())
  level         String // "error" | "warn" | "info"
  source        String // "webhook" | "ai" | "whatsapp-send" | "auth" | "credentials"
  message       String
  detail        Json?
  businessId    String?
  phoneNumberId String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
}
